# 复制为 .env 后填入真实值。.env 已在 .gitignore，不会被提交。
# 不设置任何值时全链路自动降级到本地 mock，整条链路仍可离线跑通。

OPENAI_API_KEY=sk-...

# 项目级 sk-proj-xxx key 必须配套设置；否则 OpenAI 会报 401 mismatched_project
# OPENAI_PROJECT=proj_...
# OPENAI_ORG=org_...

# 以下可选，均有默认值
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# DB_PATH=./data/runtime.db
